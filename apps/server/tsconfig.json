{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@shared/*": ["../../shared/*"]
    },
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src", "../../shared"]
}
